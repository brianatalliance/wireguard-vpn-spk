#!/bin/sh
# WireGuard VPN Tunnel for Synology DS220+
# Author:  Brian Vicente
# Version: 1.0.0
# Date:    2026-03-28
# Org:     Alliance for Empowerment
#
# start-stop-status script for WireGuard VPN Tunnel
# 
# DSM 7 runs third-party packages as a non-root "package" user.
# WireGuard requires root for TUN/network operations.
#
# Start the package via SSH:
#   sudo /var/packages/WireGuardVPN/scripts/start-stop-status start
# Or use the helper:
#   sudo /var/packages/WireGuardVPN/target/wg-tunnel-setup status

INSTALL_DIR="/var/packages/WireGuardVPN/target"
CONF_DIR="/etc/wireguard"
INTERFACE="wg0"
LOG_FILE="/var/log/wireguard-vpn.log"
PID_DIR="/var/run/wireguard"

# Ensure wireguard-go is used as the userspace implementation
export WG_QUICK_USERSPACE_IMPLEMENTATION="${INSTALL_DIR}/wireguard-go"
export PATH="${INSTALL_DIR}:${PATH}"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [WireGuardVPN] $1" >> "${LOG_FILE}" 2>/dev/null || true
}

ensure_tun() {
    if [ ! -c /dev/net/tun ]; then
        mkdir -p /dev/net 2>/dev/null
        mknod /dev/net/tun c 10 200 2>/dev/null
        chmod 666 /dev/net/tun 2>/dev/null
        log "Created /dev/net/tun device"
    fi
}

case $1 in
    start)
        log "Starting WireGuard VPN tunnel..."

        # Ensure TUN device exists
        ensure_tun

        # Enable IP forwarding
        echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null

        # Check for config file
        if [ ! -f "${CONF_DIR}/${INTERFACE}.conf" ]; then
            log "ERROR: Config file ${CONF_DIR}/${INTERFACE}.conf not found"
            echo "Config file ${CONF_DIR}/${INTERFACE}.conf not found." >&2
            echo "Edit /etc/wireguard/wg0.conf with your VPN credentials first." >&2
            exit 1
        fi

        # Check for placeholder config
        if grep -q "YOUR_PRIVATE_KEY_HERE" "${CONF_DIR}/${INTERFACE}.conf" 2>/dev/null; then
            log "ERROR: Config still has placeholder values"
            echo "Config file still has placeholder values." >&2
            echo "Edit /etc/wireguard/wg0.conf with your actual VPN credentials." >&2
            exit 1
        fi

        # Bring down existing interface if present
        if ip link show "${INTERFACE}" >/dev/null 2>&1; then
            log "Interface ${INTERFACE} already exists, bringing down first..."
            "${INSTALL_DIR}/wg-quick" down "${INTERFACE}" 2>>"${LOG_FILE}" || true
            sleep 1
        fi

        # Bring up WireGuard tunnel
        "${INSTALL_DIR}/wg-quick" up "${INTERFACE}" >>"${LOG_FILE}" 2>&1
        RC=$?

        if [ $RC -eq 0 ]; then
            mkdir -p "${PID_DIR}" 2>/dev/null
            echo "running" > "${PID_DIR}/${INTERFACE}.state" 2>/dev/null
            log "WireGuard tunnel ${INTERFACE} started successfully"

            # Log public IP for verification
            sleep 2
            PUBLIC_IP=$(curl -s --max-time 10 https://ifconfig.me 2>/dev/null || echo "unknown")
            log "Public IP after tunnel up: ${PUBLIC_IP}"
        else
            log "ERROR: Failed to start WireGuard tunnel (exit code: ${RC})"
            exit 1
        fi
        exit 0
        ;;
    stop)
        log "Stopping WireGuard VPN tunnel..."

        if ip link show "${INTERFACE}" >/dev/null 2>&1; then
            "${INSTALL_DIR}/wg-quick" down "${INTERFACE}" >>"${LOG_FILE}" 2>&1 || {
                log "wg-quick down failed, force-cleaning..."
                ip link set "${INTERFACE}" down 2>/dev/null
                ip link delete "${INTERFACE}" 2>/dev/null
            }
        fi

        rm -f "${PID_DIR}/${INTERFACE}.state" 2>/dev/null
        pkill -f "wireguard-go ${INTERFACE}" 2>/dev/null || true

        log "WireGuard tunnel stopped"
        exit 0
        ;;
    status)
        if ip link show "${INTERFACE}" >/dev/null 2>&1; then
            if "${INSTALL_DIR}/wg" show "${INTERFACE}" >/dev/null 2>&1; then
                exit 0
            fi
        fi
        # Also check state file as fallback
        if [ -f "${PID_DIR}/${INTERFACE}.state" ]; then
            exit 0
        fi
        exit 3
        ;;
    killall)
        ;;
    log)
        echo "${LOG_FILE}"
        exit 0
        ;;
esac
